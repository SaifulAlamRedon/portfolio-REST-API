# Database configuration
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=your_db_password
DB_NAME=portfolio
# You can also use a single connection string (Railway provides this):
# DATABASE_URL=postgres://user:password@host:5432/dbname
DATABASE_URL=
# App configuration
NODE_ENV=development
PORT=3006
FRONTEND_URL=http://localhost:3000

# JWT configuration
JWT_SECRET=your_jwt_secret
JWT_EXPIRES_IN=3600s

# Mailer configuration
MAILER_HOST=smtp.example.com
MAILER_PORT=587
MAILER_SECURE=false
MAILER_USER=your_smtp_username
MAILER_PASS=your_smtp_password
MAILER_FROM=no-reply@example.com
# Alternatively use MAILER_URL for a single connection string
# MAILER_URL=smtp://username:password@smtp.example.com:587

# Cloudinary configuration
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
